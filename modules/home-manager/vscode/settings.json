{
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[typst]": {
        "editor.defaultFormatter": "nvarner.typst-lsp"
    },
    "code-runner.enableAppInsights": false,
    "code-runner.runInTerminal": true,
    "code-runner.showExecutionMessage": false,
    "code-runner.showRunCommandInEditorContextMenu": false,
    "code-runner.showRunCommandInExplorerContextMenu": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.accessibilitySupport": "off",
    "editor.codeLensFontFamily": "\"Sarasa Mono SC\",monospace",
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "off",
    "editor.fontFamily": "\"Sarasa Mono SC\",monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 18,
    "editor.inlineSuggest.showToolbar": "always",
    "editor.inlineSuggest.suppressSuggestions": true,
    "editor.suggestSelection": "first",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.wordWrap": "on",
    "explorer.confirmDelete": false,
    "extensions.ignoreRecommendations": true,
    "files.autoSave": "off",
    "files.exclude": {
        "**/**.exe": true,
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.project": true,
        "**/.settings": true
    },
    "git.confirmSync": false,
    "github.gitProtocol": "ssh",
    "go.editorContextMenuCommands": {
        "addImport": false,
        "addTags": false,
        "debugTestAtCursor": false,
        "generateTestForFunction": false,
        "playground": false,
        "testAtCursor": false,
        "testCoverage": false,
        "toggleTestFile": false
    },
    "grunt.autoDetect": "on",
    "indentRainbow.colors": [
        "rgba(255,255,64,0.07)",
        "rgba(127,255,127,0.07)",
        "rgba(255,127,255,0.07)",
        "rgba(79,236,236,0.07)"
    ],
    "npm.packageManager": "bun",
    "redhat.telemetry.enabled": false,
    "search.followSymlinks": false,
    "security.workspace.trust.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    "tabnine.experimentalAutoImports": true,
    "tabnine.ignoreCertificateErrors": true,
    "tabnine.logLevel": "error",
    "telemetry.telemetryLevel": "off",
    "terminal.external.linuxExec": "alacritty",
    "terminal.integrated.defaultProfile.linux": "fish",
    "typescript.check.npmIsInstalled": false,
    "typescript.surveys.enabled": false,
    "typst-lsp.experimentalFormatterMode": "on",
    "update.mode": "none",
    "update.showReleaseNotes": false,
    "window.autoDetectColorScheme": true,
    "window.commandCenter": false,
    "window.dialogStyle": "custom",
    "window.titleBarStyle": "custom",
    "workbench.enableExperiments": false,
    "workbench.preferredLightColorTheme": "Quiet Light",
    "workbench.startupEditor": "none",
    "yaml.extension.recommendations": false
}