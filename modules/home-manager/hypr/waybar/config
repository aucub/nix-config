{
    "name": "main-bar",
    "id": "main-bar",
    "layer": "top",
    "position": "top",
    "mode": "dock",
    "exclusive": true,
    "height": 40,
    "spacing": 6,
    "fixed-center": true,
    "ipc": true,
    "modules-left": [
        "memory",
        "cpu",
        "temperature",
        "hyprland/window",
        "tray"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "pulseaudio",
        "backlight",
        "network",
        "battery",
        "custom/powermenu"
    ],
    "hyprland/workspaces": {
        "format": "{id}: {icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚρ",
            "3": "ΎΕκ",
            "4": "ΎΗ╝",
            "5": "ΎΒ╡",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "(.*) έΑΦ Mozilla Firefox": "$1",
            "(.*) - fish": "> [$1]"
        },
        "separate-outputs": true
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ΎΑΒ",
        "format-disconnected": "Disconnected ΎΑΒ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
        "interval": 10,
        "consume-icons": {
            "on": "ΎΔΕ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
            "on": "ΎΒ┤ "
        },
        "repeat-icons": {
            "on": "ΎΑη "
        },
        "single-icons": {
            "on": "ΎΑη1 "
        },
        "state-icons": {
            "paused": "ΎΒΝ",
            "playing": "ΎΒΜ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "ΌΟΞ",
            "ΌΠΥ",
            "ΌΠΣ",
            "ΌΠΠ",
            "ΌΠΟ",
            "ΌΠΞ",
            "ΌΠΛ",
            "ΌΠΙ",
            "ΌΟδ"
        ],
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "light -A 5%",
        "on-scroll-down": "light -U 5%",
        "smooth-scrolling-threshold": 1
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "ΎΑξ ΎΛΦ {volume}%",
        "format-bluetooth-muted": "Ύγσ ΎΛΦ",
        "format-muted": "≤░ΨΒ",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎθΠ",
            "headset": "ΎθΞ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "scroll-step": 2.0,
        "on-click": "amixer set Master toggle",
        "on-click-right": "pavucontrol",
        "smooth-scrolling-threshold": 1
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "≤░Β║",
            "≤░Β╗",
            "≤░Β╝",
            "≤░Β╜",
            "≤░Β╛",
            "≤░Β┐",
            "≤░ΓΑ",
            "≤░ΓΒ",
            "≤░ΓΓ",
            "≤░Β╣"
        ],
        "tooltip": false
    },
    "clock": {
        "interval": 1,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%I:%M %p  %A %b %d}",
        "tooltip": true
    },
    "memory": {
        "interval": 1,
        "format": "≤░Ξδ {percentage}%",
        "format-alt": "≤░Ξδ {used:0.1f}G",
        "states": {
            "warning": 85
        }
    },
    "cpu": {
        "interval": 1,
        "format": "≤░╗ι {usage}%"
    },
    "network": {
        "interval": 1,
        "format-wifi": "≤░Ψσ {essid}",
        "format-ethernet": "≤░ΑΓ {ifname} ({ipaddr})",
        "format-linked": "≤░Ψς {essid} (No IP)",
        "format-disconnected": "≤░ψκ Disconnected",
        "format-disabled": "≤░ψκ Disabled",
        "format-alt": "ΎΔα {bandwidthUpBits} | ΎΔΩ {bandwidthDownBits}",
        "tooltip-format": "ΎΦΓ {ifname} via {gwaddr}",
        "on-click-right": "nm-connection-editor",
        "tooltip": false
    },
    "temperature": {
        "tooltip": false,
        "format": "ΎΜΚ {temperatureC}┬░C"
    },
    "custom/powermenu": {
        "format": " ΎΑΣ ",
        "on-click": "nwg-bar",
        "tooltip": false
    },
    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}
