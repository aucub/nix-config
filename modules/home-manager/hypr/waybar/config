{
    "name": "main-bar",
    "id": "main-bar",
    "layer": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "height": 24,
    "spacing": 4,
    "margin": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "fixed-center": true,
    "ipc": true,
    "modules-left": [
        "wlr/workspaces"//,
        //"cpu",
        //"memory",
        //"disk"
    ],
    "modules-center": [
        "mpd",
        "tray"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "battery",
        "clock",
        "custom/powermenu"
    ],
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "п—қ",
            "п—ң",
            "п—һ",
            "п—ҹ"
        ],
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "light -A 5%",
        "on-scroll-down": "light -U 5%",
        "smooth-scrolling-threshold": 1
    },
    "wlr/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": true,
        "format-icons": {
            "1": "пҖ•",
            "2": "пү©",
            "3": "п„Ў",
            "4": "п„ ",
            "5": "пҒ»",
            "6": "пҖҪ",
            "7": "пҒӢ",
            "8": "пҶј",
            "9": "п„ ",
            "10": "гҖҮ",
            "focused": "пҶ’",
            "default": "пҖ•"
        }
    },
    "battery": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "full-at": 100,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "пғ§  {capacity}%",
        "format-plugged": "пҮҰ  {capacity}%",
        "format-full": "{icon}  Full",
        "format-alt": "{icon}  {time}",
        "format-icons": [
            "пү„",
            "пүғ",
            "пүӮ",
            "пүҒ",
            "пүҖ"
        ],
        "format-time": "{H}h {M}min",
        "tooltip": true
    },
    "clock": {
        "interval": 60,
        "align": 0,
        "rotate": 0,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "пҖ— {:%H:%M}",
        "format-alt": "пҒі {:%a %b %d, %G}"
    },
    "cpu": {
        "interval": 5,
        "format": "LOAD: {usage}%"
    },
    "disk": {
        "interval": 30,
        "format": "FREE: {free}"
    },
    "custom/powermenu": {
        "format": "\uf011",
        "on-click": "$HOME/.config/hypr/scripts/wlogout",
        "tooltip": false
    },
    "memory": {
        "interval": 10,
        "format": "USED: {used:0.1f}G"
    },
    "mpd": {
        "interval": 2,
        "unknown-tag": "N/A",
        "format": "{stateIcon} {artist} - {title}",
        "format-disconnected": "пўү Disconnected",
        "format-paused": "{stateIcon} {artist} - {title}",
        "format-stopped": "Stopped пҠҚ",
        "state-icons": {
            "paused": "п…„",
            "playing": "пҠӢ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "mpc toggle",
        "on-click-middle": "mpc prev",
        "on-click-right": "mpc next",
        "on-update": "",
        "on-scroll-up": "mpc seek +00:00:01",
        "on-scroll-down": "mpc seek -00:00:01",
        "smooth-scrolling-threshold": 1
    },
    "network": {
        "interval": 5,
        "format-wifi": "пҮ« {essid}",
        "format-ethernet": "пӣҝ {ipaddr}/{cidr}",
        "format-linked": "пӣҝ {ifname} (No IP)",
        "format-disconnected": "пӘ© Disconnected",
        "format-disabled": "пӘ© Disabled",
        "format-alt": "пғҳ {bandwidthUpBits} | пғ— {bandwidthDownBits}",
        "tooltip-format": "п”Ӯ {ifname} via {gwaddr}"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "п‘Ұ Mute",
        "format-bluetooth": "пҠ“ {volume}% {format_source}",
        "format-bluetooth-muted": "пҠ“ Mute",
        "format-source": "п„° {volume}%",
        "format-source-muted": "п„ұ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "пҹҸ",
            "headset": "пҹҚ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": [
                "пҖҰ",
                "пҖ§",
                "пҖЁ"
            ]
        },
        "scroll-step": 5.0,
        "on-click": "amixer set Master toggle",
        "on-click-right": "pavucontrol",
        "smooth-scrolling-threshold": 1
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}