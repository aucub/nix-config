{
    "name": "main-bar",
    "id": "main-bar",
    "layer": "top",
    "mode": "dock",
    "exclusive": true,
    "passthrough": false,
    "height": 18,
    "spacing": 2,
    "margin": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "fixed-center": true,
    "ipc": true,
    "modules-left": [
        "wlr/workspaces",
        "memory",
        "cpu",
        "temperature",
        #"idle_inhibitor",
        "custom/wall",
        "mpd",
        "custom/cava-internal"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "pulseaudio",
        "backlight",
        "network",
        "battery",
        "custom/powermenu",
        "tray"
    ],
    "custom/cava-internal": {
        "exec": "sleep 1s && cava-internal",
        "tooltip": false
    },
    "wlr/workspaces": {
        "format": "{icon}",
        "on-click": "activate"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░",
        },
        "tooltip": false,
    },
    "backlight": {
        "interval": 2,
        "align": 0,
        "rotate": 0,
        "format": "{icon} {percent}%",
        "format-icons": [
            "ΌΟΞ",
            "ΌΠΥ",
            "ΌΠΣ",
            "ΌΠΠ",
            "ΌΠΟ",
            "ΌΠΞ",
            "ΌΠΛ",
            "ΌΠΙ",
            "ΌΟδ"
        ],
        "on-click": "",
        "on-click-middle": "",
        "on-click-right": "",
        "on-update": "",
        "on-scroll-up": "light -A 5%",
        "on-scroll-down": "light -U 5%",
        "smooth-scrolling-threshold": 1
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "ΎΑξ ΎΛΦ {volume}%",
        "format-bluetooth-muted": "Ύγσ ΎΛΦ",
        "format-muted": "≤░ΨΒ",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎθΠ",
            "headset": "ΎθΞ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο" "ΎΑπ" "ΎΑρ"]
        },
        "scroll-step": 2.0,
        "on-click": "amixer set Master toggle",
        "on-click-right": "pavucontrol",
        "smooth-scrolling-threshold": 1
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["≤░Β║" "≤░Β╗" "≤░Β╝" "≤░Β╜" "≤░Β╛" "≤░Β┐" "≤░ΓΑ" "≤░ΓΒ" "≤░ΓΓ" "≤░Β╣"],
        "tooltip": false
    },
    "clock": {
        "interval": 1,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%I:%M %p  %A %b %d}",
        "tooltip": true
    },
    "memory": {
        "interval": 1,
        "format": "≤░Ξδ {percentage}%",
        "format-alt": "≤░Ξδ {used:0.1f}G",
        "states": {
            "warning": 85
        }
    },
    "cpu": {
        "interval": 1,
        "format": "≤░╗ι {usage}%"
    },
    "mpd": {
        "max-length": 25,
        "interval": 2,
        "unknown-tag": "N/A",
        "format": "<span foreground='#bb9af7'>ΎΑΒ</span> {title}",
        "format-disconnected": " Disconnected",
        "format-paused": "ΎΑΒ {title}",
        "format-stopped": "<span foreground='#bb9af7'>ΎΑΒ</span>",
        "tooltip-format": "{title} - {artist} ({elapsedTime:%M:%S}/{totalTime:%H:%M:%S})",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "mpc toggle",
        "on-click-middle": "mpc prev",
        "on-click-right": "mpc next",
        "on-update": "",
        "on-scroll-up": "mpc seek +00:00:01",
        "on-scroll-down": "mpc seek -00:00:01",
        "smooth-scrolling-threshold": 5
    },
    "network": {
        "interval": 1,
        "format-wifi": "≤░Ψσ {essid}",
        "format-ethernet": "≤░ΑΓ {ifname} ({ipaddr})",
        "format-linked": "≤░Ψς {essid} (No IP)",
        "format-disconnected": "≤░ψκ Disconnected",
        "format-disabled": "≤░ψκ Disabled",
        "format-alt": "ΎΔα {bandwidthUpBits} | ΎΔΩ {bandwidthDownBits}",
        "tooltip-format": "ΎΦΓ {ifname} via {gwaddr}",
        "on-click-right": "nm-connection-editor",
        "tooltip": false
    },
    "temperature": {
        "tooltip": false,
        "format": "ΎΜΚ {temperatureC}┬░C"
    },
    "custom/powermenu": {
        "format": " <span color='#6a92d7'>έΠ╗ </span>",
        "on-click": "nwg-bar",
        "tooltip": false
    },
    "tray": {
        "icon-size": 15,
        "spacing": 5
    }
}